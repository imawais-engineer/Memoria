DASHSCOPE_API_KEY=your_key
# Optional alias accepted by the backend if DASHSCOPE_API_KEY is unset:
# QWEN_DASHSCOPE_API=your_key
# Optional: DashScope endpoint override (set to the intl endpoint for
# international-region keys). Leave blank for the SDK default (Beijing).
DASHSCOPE_BASE_URL=
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/memoria
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=supersecret
